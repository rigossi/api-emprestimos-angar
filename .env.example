# Configurações do Servidor
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=sua_chave_secreta_jwt_aqui_muito_segura
JWT_EXPIRES_IN=3600

# WhatsApp Business API (Meta)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_ACCESS_TOKEN=seu_token_de_acesso_permanente
WHATSAPP_TEMPLATE_NAME=proposta_emprestimo_confirmacao

# Webhook Security
KEY_ANGAR=sua_chave_secreta_para_assinatura_webhook

# Base URL da aplicação (para gerar links de confirmação)
APP_BASE_URL=https://api.angar.com.br
